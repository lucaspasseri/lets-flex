<div class="svg-container">
	<svg
		class="logo-svg"
		viewBox="0 0 760 260"
		preserveAspectRatio="xMidYMid meet"
		role="img"
		aria-label="Let's Flex neon SVG logo"
	>
		<defs>
			<linearGradient
				id="frameGradient"
				x1="120"
				y1="40"
				x2="640"
				y2="220"
				gradientUnits="userSpaceOnUse"
			>
				<stop offset="0%" stop-color="#ff4fd8" />
				<stop offset="100%" stop-color="#5fd8ff" />
			</linearGradient>

			<linearGradient
				id="accentGradient"
				x1="230"
				y1="0"
				x2="520"
				y2="0"
				gradientUnits="userSpaceOnUse"
			>
				<stop offset="0%" stop-color="#ff4fd8" />
				<stop offset="100%" stop-color="#5fd8ff" />
			</linearGradient>

			<radialGradient id="glowGradient" cx="50%" cy="50%" r="50%">
				<stop offset="0%" stop-color="#5fd8ff" stop-opacity="0.9" />
				<stop offset="55%" stop-color="#ff4fd8" stop-opacity="0.5" />
				<stop offset="100%" stop-color="#000000" stop-opacity="0" />
			</radialGradient>
		</defs>

		<g transform="translate(380 130) scale(1.7) translate(-380 -130)">
			<circle class="soft-glow" cx="380" cy="130" r="300" />
			<circle class="frame-path" cx="380" cy="130" r="200" stroke-width="6" />
			<text class="lets-text" x="186" y="80">Let's</text>
			<text class="flex-text" x="240" y="190">FLEX</text>
			<path class="accent-line" d="M 244 206 C 318 198, 425 199, 570 190" />
		</g>
	</svg>
</div>
