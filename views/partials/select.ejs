<% 
const optionsArr = data?.options || []; 
const label = data?.label || "Select option"; 
const name = data?.name || "select-option"; 
const id = data?.id || name;
%>

<div class="select">
	<label for="<%= id %>"><%= label %></label>

	<select id="<%= id %>" name="<%= name %>" required>
		<option value="" selected hidden>Select an option...</option>

		<% optionsArr.forEach(option => { %>
			<option value="<%= option.id ?? option %>">
				<%= option.name ?? option %>
			</option>
		<% }); %>
	</select>
</div>