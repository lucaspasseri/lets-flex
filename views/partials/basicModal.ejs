<%
const modal = locals?.modal || {};
const id = modal.id || "modal";
const title = modal.title || "Modal";
const description = modal.description || "";
const content = modal.content || "";
const confirmText = modal.confirmText || "";
const cancelText = modal.cancelText || "Cancel";
const formAction = modal.formAction || "";
const formMethod = modal.formMethod || "POST";
%>

<div
	class="modal"
	id="<%= id %>"
	hidden
	aria-hidden="true"
>
	<div class="modal-backdrop" data-modal-close></div>

	<div
		class="modal-dialog"
		role="dialog"
		aria-modal="true"
		aria-labelledby="<%= id %>-title"
		<% if (description) { %>
			aria-describedby="<%= id %>-description"
		<% } %>
	>
		<div class="modal-header">
			<h2 id="<%= id %>-title" class="modal-title"><%= title %></h2>

			<button
				type="button"
				class="modal-close"
				aria-label="Close modal"
				data-modal-close
			>
				×
			</button>
		</div>

		<div class="modal-body">
			<% if (description) { %>
				<p id="<%= id %>-description" class="modal-description">
					<%= description %>
				</p>
			<% } %>

			<%- content %>
		</div>

		<% if (confirmText) { %>
			<div class="modal-footer">
				<button
					type="button"
					class="button button-secondary"
					data-modal-close
				>
					<%= cancelText %>
				</button>

				<form action="<%= formAction %>" method="<%= formMethod %>">
					<button type="submit" class="button button-danger">
						<%= confirmText %>
					</button>
				</form>
			</div>
		<% } %>
	</div>
</div>