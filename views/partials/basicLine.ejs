<%
const title = line?.title || "";
const arr = line?.arr || [];
const modalId = line?.modalId || "0";
%>

<div>
	<h1><%= title %></h1>

	<div class="line">
		<ul>
			<% arr.forEach(item => { %>
				<li>
					<div class="card">
						<p><%= item.name %></p>
					</div>
				</li>
			<% }) %>
		</ul>
		<div class="button-container card">
			<button
				type="button"
				class="button"
				data-modal-open="<%= modalId %>"
			>
				<span>+</span>
			</button>
		</div>
	</div>
</div>