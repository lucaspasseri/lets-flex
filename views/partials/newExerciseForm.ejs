<%
const movementPatternArr = locals?.movementPatternArr || [];
const equipmentArr = locals?.equipmentArr || [];
const muscleArr = locals?.muscleArr || [];
const muscleRoleArr = locals?.muscleRoleArr || [];
%>

<form class="forms" action="/exercise_cluster" method="POST">
	<%- include('../partialsOld/olaInput', { data: { label: "Name", type: "text", name: "name", context: "newExerciseForm", autocomplete: "name", required: true } }); %>
	<%- include("../partialsOld/select", { data: { id: "movementPatternId", label: "Movement pattern", name: "movementPatternId",
	options: movementPatternArr, getOptionLabel: (movementPattern) => movementPattern.name, getOptionValue: (movementPattern) => movementPattern.id  } }); %>
	<%- include("../partialsOld/select", { data: { id: "equipmentId", label: "Equipment", name: "equipmentId",
	options: equipmentArr, getOptionLabel: (equipment) => equipment.name, getOptionValue: (equipment) => equipment.id  } }); %>

	<div>
		<%- include("../partialsOld/select", { data: { id: "muscleIdSelect", label: "Performing muscle",
		options: muscleArr, getOptionLabel: (muscle) => muscle.common_name, getOptionValue: (muscle) => muscle.id } }); %>	

		<%- include("../partialsOld/select", { data: { id: "muscleRoleIdSelect", label: "Muscle role", 
		options: muscleRoleArr, getOptionLabel: (muscle_role) => muscle_role.name, getOptionValue: (muscle_role) => muscle_role.id } }); %>	

		<button type="button" id="addMusclePerformingRoleButton" >Add to the performing muscle list</button>
	</div>

	<ul id="musclePerformingList"></ul>

	<%- include('../partialsOld/simpleButton', { data: { text: "Submit", type: "submit" } }); %>
</form>

<script>
	const addButton = document.getElementById("addMusclePerformingRoleButton");
	const list = document.getElementById("musclePerformingList");

	const muscleSelect = document.getElementById("muscleIdSelect");
	const muscleRoleSelect = document.getElementById("muscleRoleIdSelect");

	addButton.addEventListener("click", () => {
		const index = Array.from(list.querySelectorAll("li")).length;

		const muscleId = muscleSelect.value;
		const muscleName = muscleSelect.options[muscleSelect.selectedIndex].text;

		const muscleRoleId = muscleRoleSelect.value;
		const muscleRoleName = muscleRoleSelect.options[muscleRoleSelect.selectedIndex].text;

		if (!muscleId || !muscleRoleId) return;

		const item = document.createElement("li");

		const summary = document.createElement("p");
		summary.textContent = `${muscleName} — ${muscleRoleName}`;

		const muscleInput = document.createElement("input");
		muscleInput.type = "hidden";
		muscleInput.name = `muscleGroup[${index}][muscleId]`;
		muscleInput.value = muscleId;

		const roleInput = document.createElement("input");
		roleInput.type = "hidden";
		roleInput.name = `muscleGroup[${index}][muscleRoleId]`;
		roleInput.value = muscleRoleId;

		const removeButton = document.createElement("button");
		removeButton.type = "button";
		removeButton.textContent = "Remove";
		removeButton.addEventListener("click", () => item.remove());

		item.append(summary, muscleInput, roleInput, removeButton);
		list.appendChild(item);
	});
</script>