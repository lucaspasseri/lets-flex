<%
let movementPatternsArr = locals?.movementPatternsArr || [];
%>

<form class="forms" action="/sessions" method="POST">

	<input hidden type="text" name="cycleId" value="<%= currCycleId %>" />
	<%- include('../partialsOld/olaInput', { data: { label: "Name", type: "text", name: "name", context: "sessionForm", autocomplete: "name", required: true } }); %>
	<%- include("../partialsOld/select", { data: { id: "sessionOrderSelect", label: "Session Order", name: "sessionOrder", required: true, 
	options: sessionArr, getOptionLabel: (session) => session.session_order, getOptionValue: (session) => session.session_order  } }); %>

	<%- include('../partialsOld/simpleButton', { data: { text: "Submit", type: "submit" } }); %>
</form>

