<%
const currentUrl = locals?.url || ""; 
const tabs = [{href: "/", label: "Dashboard"}, {href: "/programs", label: "Programs"}, {href: "/library", label: "Library"}, {href: "/profile", label: "Profile"}];


const setIndicator = (tab) => {
	if(tab.href === "/"){
		if(currentUrl === "/"){
			return "footer-indicator isActive";		
		}
		
		return "footer-indicator";	
	}

	const active = currentUrl.includes(tab.href) ? "isActive" : "";
	return `footer-indicator ${active}`;
}
%>

<footer class="footer">
	<nav class="footer-nav">
		<ul>
			<% tabs.forEach(tab => { %>
				<li>
					<a href="<%= tab.href %>">
					<span 
						><%= tab.label %></span
					>
					<span
						class="<%= setIndicator(tab) %>"
						aria-hidden="true"
					></span>
				</a>
				</li>
			<% }) %>
		</ul>
	</nav>
</footer>