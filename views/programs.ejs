<% 
const programBasicLineId = "programsPageProgramBasicLine";
const programBasicLineEntity = "program";
const programArr = locals?.programArr || [];
const createProgramModalId = "createProgramModal";
const currProgramId = locals?.currProgramId || null;
const chosenProgramPath = "/programs/";

const cycleBasicLineId = "cyclesPageCycleBasicLine";
const cycleBasicLineEntity = "cycle";
const cycleArr = locals?.cycleArr || [];
const createCycleModalId = "createCycleModal";
const currCycleId = locals?.currCycleId || null;
const chosenCyclePath = `/programs/${currProgramId}/cycles/`;


const sessionArr = locals?.sessionArr || [];

const currUserId = locals?.currentUser?.id || null;
const currProgram = locals?.currentProgram || {};
const currSessionId = locals?.currSessionId || null;
const currDayId = locals?.currDayId || null;


const startDate = currProgram?.start_date && new Date(currProgram.start_date) || new Date();

const trainingDayArr = locals?.trainingDayArr || [];

	const getClassName = (index, trainingDay, currCycleId) => {
		let className = "";

		if(index === 0){
			className += "startDate ";
		}

		if(trainingDay.cycle_id === null){
			className += "no-cycle";
			return className;
		}

		if(trainingDay.cycle_id === currCycleId){
			className += "day-selected";
			return className;
		}

		className += "cycle-not-selected";
		return className;
	}


const dayArr = trainingDayArr.map((trainingDay, index) => {
	const hasCycleSelected = currCycleId === trainingDay.cycle_id && currCycleId !== null;
	const date = formatDate(addDays(startDate, index ), "dd/MM/yyyy");
	const className = getClassName(index, trainingDay, currCycleId);

	return {
		id: index,
		trainingDayId: trainingDay.training_day_id,
		hasCycleSelected,
		date, 
		className,
	}
});

const getHref = (dayId) => {
	const path = `/programs/day/${dayId}`;

	return path;
}

%>

<main class="main programs">
	<div>
		<% if(currUserId){ %>
			<h1>CHOOSE THE ACTIVE PROGRAM</h1>
				<%- include("partials/newBasicLine", {line: { basicLineId: programBasicLineId, entity: programBasicLineEntity, arr: programArr, modalId: createProgramModalId, currentItemId: currProgramId, path: chosenProgramPath }}) %>
			<% if(currProgramId) { %>
				<h2>Cycles</h2>
				<%- include("partials/newBasicLine", {line: { basicLineId: cycleBasicLineId, entity: cycleBasicLineEntity, arr: cycleArr, modalId: createCycleModalId, currentItemId: currCycleId, path: chosenCyclePath }}) %>
			<% } %>
		<% } %>
	</div>

	<div class="basic-calendar"> 
		<ul class="list">
			<% dayArr.forEach((day) => { %>
				<li class="session-component <%= day.className %>" data-calendar-day-id="<%= day.trainingDayId %>"> 
					<div class="container">
						<% if(day?.hasCycleSelected) { %>
							<a data-calendar-day-date="<%= day.date %>"  href="<%= getHref(day.trainingDayId) %>">
								<p>	<%= day.date %></p>
							</a>
						<% } else { %>
							<p >
								<%= day.date %>
							</p>
						<% } %>
					</div>
				</li>
			<% }) %>
		</ul>
	</div>
</main>

<%- contentFor("overlays") %>

<%- include("partials/basicModal", {
	modal: {
		id: createProgramModalId,
		title: "Create program",
		description: "Fill in the program information below.",
		renderContent: () => include("partials/newProgramForm")
	}
}) %>

<%- include("partials/basicModal", {
	modal: {
		id: createCycleModalId,
		title: "Create cycle",
		description: "Fill in the cycle information below.",
		renderContent: () => include("partials/cycleForm")
	}
}) %>