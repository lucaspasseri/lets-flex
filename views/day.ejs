<%
const currProgram = locals?.currentProgram || {};
const currCycleId = locals?.currCycleId || null; 
const currDayId = locals?.currDayId || null;
const backUrl = locals?.backUrl || "";
const scheduleDate = locals?.scheduleDate || null;
const formattedScheduleDate = scheduleDate ? locals.formatDate(scheduleDate, "dd/MM/yyyy") : "No date";

const sessionBasicLineId = "dayPageSessionBasicLine";
const sessionBasicLineEntity = "session";
const sessionArr = locals?.sessionArr || [];
const createSessionModalId = "createSessionModal";
const currSessionId = locals?.currSessionId || null;
const chosenSessionPath = `/programs/day/${currDayId}/sessions/`;

const createSessionStepModalId = "createSessionStepModal";
const sessionStepArr = locals?.sessionStepArr || [];
const trainingDayArr = locals?.trainingDayArr || [];

console.log({trainingDayArr});

const startDate = currProgram?.start_date && new Date(currProgram.start_date) || new Date();

console.log({ startDate });

const getScheduleDate = (index) => {
	const date = formatDate(addDays(startDate, index ), "dd/MM/yyyy");
	return date;
}

const getNavLinkHref = (trainingDay) => {
	return `/programs/day/${trainingDay.training_day_id}`;
}

%>
<main class="main day">
	<% if(trainingDayArr.length > 0){ %>
		<nav class="day-rail-wrapper">
			<button class="day-arrow" data-scroll-left>‹</button>
			<ul class="day-rail" id="dayRail">
				<% trainingDayArr.forEach((trainingDay,index) => { %>
					<li><a href="<%= getNavLinkHref(trainingDay) %>" class="day-card <%= currDayId === trainingDay.training_day_id ? 'active' : '' %>"><%= getScheduleDate(index) %></a></li>
				<% }) %>
			</ul>
			<button class="day-arrow" data-scroll-right>›</button>
		</nav>
	<% } %>

	<div class="current-day-container">
		<h1><%= formattedScheduleDate %></h1>
	</div>

	<div class="session-component" data-calendar-day-id="<%= currDayId %>">
		<div class="container session-selected">
			<% if( sessionArr.length === 0){ %>
					<div>
						<h1>SESSION<br />INITIALIZATION</h1>
						<p>
							Enter precise baseline metric to calibrate the performance engine.
							Accuracy is required for optimal load calculation and volume prescription.
						</p>
				</div>
			<% } else { %>
				<h2>CHOOSE THE ACTIVE SESSION</h2>
			<% } %>
			<%- include("partials/newBasicLine", {line: { basicLineId: sessionBasicLineId, entity: sessionBasicLineEntity, arr: sessionArr, modalId: createSessionModalId, currentItemId: currSessionId, path: chosenSessionPath }}) %>

			<div class="session-step-container">
				<h3>Exercises (session steps)</h3>
				<button type="button"class="button" data-modal-open="<%= createSessionStepModalId %>">ADD EXERCISE</button>
				<% if (sessionStepArr.length > 0) { %>
					<ul>
						<% sessionStepArr.forEach(step => { %>
							<li>
								<p><%= `(${step.id}) - ${step.name} ` %></p>
							</li>
						<% }) %>
					</ul>
				<% } %>	
			 </div>
			</div>
		</div>
	</div>
</main>

<script>
	const rail = document.getElementById("dayRail");
	const activeDay = rail?.querySelector(".day-card.active");

	activeDay?.scrollIntoView({
		behavior: "instant",
		inline: "center",
		block: "nearest",
	});

	document.querySelector("[data-scroll-left]")?.addEventListener("click", () => {
		rail.scrollBy({ left: -240, behavior: "smooth" });
	});

	document.querySelector("[data-scroll-right]")?.addEventListener("click", () => {
		rail.scrollBy({ left: 240, behavior: "smooth" });
	});
</script>

<%- contentFor("overlays") %>

<%- include("partials/basicModal", {
	modal: {
		id: createSessionModalId,
		title: "Create session",
		description: "Fill in the session information below.",
		renderContent: () => include("partials/sessionForm")
	}
}) %>

<%- include("partials/basicModal", {
	modal: {
		id: createSessionStepModalId,
		title: "Create session step",
		description: "Fill in the step information below.",
		renderContent: () => include("partials/stepForm")
	}
}) %>